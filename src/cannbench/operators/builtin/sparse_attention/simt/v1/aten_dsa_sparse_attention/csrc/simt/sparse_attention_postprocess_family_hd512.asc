#include <cstdint>
#include <limits>
#include <math.h>

#include "acl/acl.h"
#include "simt_api/asc_simt.h"

namespace {

constexpr int32_t kHeadDim = 512;
constexpr int32_t kSelectedTokenUpperBound = 1024;

template <typename T>
struct Add {
  __aicore__ inline T operator()(T a, T b) const {
    return a + b;
  }
};

template <typename T>
struct Max {
  __aicore__ inline T operator()(T a, T b) const {
    return a < b ? b : a;
  }
};

template <typename T, template <typename> class ReduceOp>
__aicore__ inline T row_block_reduce(
    __ubuf__ T* shared,
    T val) {
  ReduceOp<T> reduce_op;

  __syncthreads();
  shared[threadIdx.x] = val;

  int offset = blockDim.x / 2;
  while (offset > 0) {
    __syncthreads();
    if (threadIdx.x < offset) {
      shared[threadIdx.x] = reduce_op(
          shared[threadIdx.x],
          shared[threadIdx.x + offset]);
    }
    offset /= 2;
  }

  __syncthreads();
  return shared[0];
}

__global__ void sparse_attention_postprocess_family_hd512_kernel(
    const float* scores,
    const float* selected_values,
    const int32_t* indices,
    float* output,
    float* lse,
    int32_t batch_size,
    int32_t query_heads,
    int32_t query_tokens,
    int32_t selected_tokens,
    int32_t query_start,
    bool causal) {
  extern __ubuf__ uint32_t dynamicStartUB[];
  auto shared = (__ubuf__ float*)dynamicStartUB;

  for (int64_t linear_index = blockIdx.x;
       linear_index < static_cast<int64_t>(batch_size) * query_heads * query_tokens;
       linear_index += gridDim.x) {
    const int32_t query_index = static_cast<int32_t>(linear_index % query_tokens);
    const int64_t row_index = linear_index / query_tokens;
    const int32_t head_index = static_cast<int32_t>(row_index % query_heads);
    const int32_t batch_index = static_cast<int32_t>(row_index / query_heads);

    const int64_t output_base =
        ((static_cast<int64_t>(batch_index) * query_heads + head_index) * query_tokens +
         query_index) *
        kHeadDim;
    const int64_t index_base =
        (static_cast<int64_t>(batch_index) * query_tokens + query_index) *
        selected_tokens;
    const int64_t score_base =
        ((static_cast<int64_t>(batch_index) * query_heads + head_index) * query_tokens +
         query_index) *
        selected_tokens;
    const int64_t value_base =
        ((((static_cast<int64_t>(batch_index) * query_heads + head_index) * query_tokens +
           query_index) *
          selected_tokens) *
         kHeadDim);

    float local_valid = 0.0F;
    float local_max = -std::numeric_limits<float>::infinity();
    for (int32_t selected_index = threadIdx.x; selected_index < selected_tokens;
         selected_index += blockDim.x) {
      const int32_t token_index = indices[index_base + selected_index];
      if (token_index < 0) {
        continue;
      }
      if (causal && token_index > (query_start + query_index)) {
        continue;
      }
      const float score = scores[score_base + selected_index];
      local_valid = 1.0F;
      local_max = Max<float>()(local_max, score);
    }

    const float valid_count = row_block_reduce<float, Add>(shared, local_valid);
    if (valid_count == 0.0F) {
      for (int32_t dim_index = threadIdx.x; dim_index < kHeadDim; dim_index += blockDim.x) {
        output[output_base + dim_index] = 0.0F;
      }
      if (threadIdx.x == 0) {
        lse[linear_index] = -std::numeric_limits<float>::infinity();
      }
      continue;
    }

    const float max_score = row_block_reduce<float, Max>(shared, local_max);

    float local_sum_exp = 0.0F;
    for (int32_t selected_index = threadIdx.x; selected_index < selected_tokens;
         selected_index += blockDim.x) {
      const int32_t token_index = indices[index_base + selected_index];
      if (token_index < 0) {
        continue;
      }
      if (causal && token_index > (query_start + query_index)) {
        continue;
      }
      const float score = scores[score_base + selected_index];
      local_sum_exp += __expf(score - max_score);
    }

    const float sum_exp = row_block_reduce<float, Add>(shared, local_sum_exp);
    const float inv_sum = sum_exp > 0.0F ? 1.0F / sum_exp : 0.0F;
    if (threadIdx.x == 0) {
      for (int32_t dim_index = 0; dim_index < kHeadDim; ++dim_index) {
        float weighted_output = 0.0F;
        for (int32_t selected_index = 0; selected_index < selected_tokens; ++selected_index) {
          const int32_t token_index = indices[index_base + selected_index];
          if (token_index < 0) {
            continue;
          }
          if (causal && token_index > (query_start + query_index)) {
            continue;
          }
          const float score = scores[score_base + selected_index];
          const float probability = __expf(score - max_score) * inv_sum;
          weighted_output +=
              probability *
              selected_values[value_base +
                              static_cast<int64_t>(selected_index) * kHeadDim + dim_index];
        }
        output[output_base + dim_index] = weighted_output;
      }
      lse[linear_index] = max_score + logf(sum_exp);
    }
  }
}

} // namespace

extern "C" void launch_sparse_attention_hd512_postprocess_float(
    const float* scores,
    const float* selected_values,
    const int32_t* indices,
    float* output,
    float* lse,
    int64_t batch_size,
    int64_t query_heads,
    int64_t query_tokens,
    int64_t selected_tokens,
    int64_t query_start,
    bool causal,
    aclrtStream stream) {
  constexpr uint32_t kThreadsPerBlock = 256;
  constexpr uint32_t kMaxBlocks = 256;
  const uint32_t dynamic_ubuf_bytes = kThreadsPerBlock * sizeof(float);

  uint32_t blocks_per_grid =
      static_cast<uint32_t>(batch_size * query_heads * query_tokens);
  if (blocks_per_grid > kMaxBlocks) {
    blocks_per_grid = kMaxBlocks;
  }
  if (blocks_per_grid < 1) {
    blocks_per_grid = 1;
  }

  sparse_attention_postprocess_family_hd512_kernel
      <<<blocks_per_grid, kThreadsPerBlock, dynamic_ubuf_bytes, stream>>>(
      scores,
      selected_values,
      indices,
      output,
      lse,
      static_cast<int32_t>(batch_size),
      static_cast<int32_t>(query_heads),
      static_cast<int32_t>(query_tokens),
      static_cast<int32_t>(selected_tokens),
      static_cast<int32_t>(query_start),
      causal);
}
